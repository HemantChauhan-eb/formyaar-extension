      </div>

      ${
        required && isDisabled
          ? '<div id="fy-warning" style="font-size:11px;color:#dc3545;margin-top:8px;display:none;">Please fill this field before continuing.</div>'
          : ""
      }
    </div>

    <!-- FOOTER -->
    <div style="
      background:#fff;
